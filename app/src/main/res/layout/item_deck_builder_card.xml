<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_item_parchment"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md"
    android:layout_marginBottom="@dimen/spacing_sm">

    <!-- Faction color border -->
    <View
        android:id="@+id/faction_border"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@color/outline" />

    <!-- Card info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_card_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/domine_bold"
            android:textColor="#4a3520"
            android:textSize="@dimen/text_body_md"
            tools:text="Strike" />

        <TextView
            android:id="@+id/tv_card_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fontFamily="@font/space_grotesk"
            android:textColor="#6b5a40"
            android:textSize="@dimen/text_label_sm"
            tools:text="Basic attack" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_card_attack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:textColor="#6b5a40"
                android:textSize="@dimen/text_label_sm"
                tools:text="ATK: 3" />

            <TextView
                android:id="@+id/tv_card_defense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:fontFamily="@font/space_grotesk"
                android:textColor="#6b5a40"
                android:textSize="@dimen/text_label_sm"
                tools:text="DEF: 2" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action button -->
    <LinearLayout
        android:id="@+id/btn_card_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bronze_button"
        android:gravity="center"
        android:padding="@dimen/spacing_sm">

        <TextView
            android:id="@+id/tv_action_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:text="@string/deck_builder_add"
            android:textColor="@color/on_primary_container"
            android:textSize="@dimen/text_label_sm" />
    </LinearLayout>
</LinearLayout>
