<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Mana cost will be drawn by CardViewCustom onDraw -->

    <!-- Card Name -->
    <TextView
        android:id="@+id/tv_card_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/space_grotesk"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="1"
        tools:text="Strike" />

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Attack Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/surface_container_lowest"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_card_attack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:text="⚔"
                android:textColorHint="#c0392b" />

            <TextView
                android:id="@+id/tv_card_attack_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                tools:text="3" />
        </LinearLayout>

        <!-- Defense Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@color/surface_container_lowest"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_card_defense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:text="🛡"
                android:textColorHint="#4a9bd9" />

            <TextView
                android:id="@+id/tv_card_defense_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                tools:text="2" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mana cost text (drawn in circle by CardViewCustom) -->
    <TextView
        android:id="@+id/tv_mana_cost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/domine_bold"
        android:textColor="@color/on_primary_container"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="1" />

</merge>
